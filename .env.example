# LLM / Agent
MODEL_NAME=kimi-code:kimi-for-coding
SUMMARY_MODEL=kimi-code:kimi-for-coding
KIMI_PROTOCOL=anthropic
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
ENABLE_TOOLS=1
DRY_RUN=0
THREAD_ID=v1_0
STORE_ID=v1_0
LOCAL_IMG=1
FORMAT=1
MEM_EMBED_MODEL=none
MEM_EMBED_DIMS=1536

# Database
LANGGRAPH_PG=postgresql://languser:langpass@localhost:5432/langgraph
SYS_MSG_FILE=./prompts/default.txt
THREAD_STORE_FILE=.qq_group_threads.json
REMINDER_STORE_FILE=.qq_reminder_threads.json
MEMORY_STORE_FILE=.qq_group_memnames.json

# Keys
# Kimi Code Anthropic-compatible path（推荐当前部署）
KIMI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.kimi.com/coding/

# Kimi Code / Kimi Platform OpenAI-compatible path（可选）
MOONSHOT_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_OPENAI_BASE_URL=https://api.kimi.com/coding/v1

# Gemini / Vertex（生图或切回 Gemini 主模型时需要）
GOOGLE_APPLICATION_CREDENTIALS=/app/secret/xxxxxxxx.json
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=projectID
GOOGLE_CLOUD_LOCATION=global

GEMINI_API_KEY=
TAVILY_API_KEY=
OPENWEATHERMAP_API_KEY=
SERPAPI_API_KEY=
RAPIDAPI_KEY=
RAPIDAPI_HOTEL_HOST=
VISUAL_CROSSING_API_KEY=


# Net
BOT_HOST=0.0.0.0
BOT_PORT=8080
ONEBOT_API_BASE=http://127.0.0.1:3001
ONEBOT_SECRET=
ONEBOT_ACCESS_TOKEN=

# QQ Bot
ALLOWED_GROUPS=
BLACKLIST_GROUPS=
LIMIT_GROUPS=
CMD_ALLOWED_USERS=
DAILY_TASK=
DAILY_TASK_TIME=
NIGHTLY_TASK=
NIGHTLY_TASK_TIME=
TICKET_TASK=
TICKET_TASK_TIME=
X_MONITOR_NEW_POST_NOTICE=0
X_MONITOR_TRANSLATION_MODE=none
X_MONITOR_SOURCE=api
X_MONITOR_BROWSER_TIMEOUT_MS=30000
X_MONITOR_BROWSER_WAIT_MS=2500

# 其他
WAIT_PG=1
